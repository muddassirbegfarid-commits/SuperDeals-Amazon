rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "muddassirbegfarid@gmail.com";
    }

    match /products/{productId} {
      // Public read access
      allow read: if true;

      // Admin can do everything
      allow create, delete: if isAdmin();
      
      // Update rule: Admin can update anything, 
      // Public can only update clicks and rotation metadata
      allow update: if isAdmin() || 
                    (
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks', 'lastClickedAt', 'lastShownDate']) &&
                      (
                        !('clicks' in request.resource.data.diff(resource.data).affectedKeys()) ||
                        request.resource.data.clicks == resource.data.clicks + 1
                      )
                    );
    }
  }
}
